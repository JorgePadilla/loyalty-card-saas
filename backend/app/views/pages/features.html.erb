<% content_for(:title, "Features") %>

<section class="max-w-6xl mx-auto px-6 pt-24 pb-16">
  <div class="max-w-3xl">
    <h1 class="text-4xl font-semibold">Built for businesses<br>that value their customers</h1>
    <p class="text-xl text-secondary mt-4">Everything you need to run a world-class loyalty program, without the complexity.</p>
  </div>
</section>

<!-- Feature sections -->
<section class="max-w-6xl mx-auto px-6 py-16">
  <div class="space-y-24">
    <!-- QR Check-ins -->
    <div class="grid grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-xs text-gold uppercase tracking-widest font-medium">Effortless</p>
        <h2 class="text-3xl font-semibold mt-3">QR Code Check-ins</h2>
        <p class="text-secondary mt-4">Customers open the app. Staff scans. Points are awarded. The entire flow takes under 5 seconds.</p>
        <ul class="mt-6 space-y-3">
          <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success">✓</span> HMAC-signed QR codes for security</li>
          <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success">✓</span> Works with any phone camera</li>
          <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success">✓</span> Instant points and visit tracking</li>
        </ul>
      </div>
      <div class="bg-surface border border-border rounded-2xl p-8 flex items-center justify-center h-64">
        <div class="text-center">
          <div class="w-24 h-24 mx-auto bg-surface-variant rounded-xl flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-matte" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 3.75 9.375v-4.5ZM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 0 1-1.125-1.125v-4.5ZM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0 1 13.5 9.375v-4.5Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 6.75h.75v.75h-.75v-.75ZM6.75 16.5h.75v.75h-.75v-.75ZM16.5 6.75h.75v.75H16.5v-.75ZM13.5 13.5h.75v.75h-.75v-.75ZM13.5 19.5h.75v.75h-.75v-.75ZM19.5 13.5h.75v.75h-.75v-.75ZM19.5 19.5h.75v.75h-.75v-.75ZM16.5 16.5h.75v.75H16.5v-.75Z" /></svg>
          </div>
          <p class="text-sm text-secondary mt-3">Scan to check in</p>
        </div>
      </div>
    </div>

    <!-- Dashboard -->
    <div class="grid grid-cols-2 gap-16 items-center">
      <div class="bg-surface border border-border rounded-2xl p-8 h-64 flex items-center justify-center">
        <div class="w-full space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-xs text-secondary">Visits today</span>
            <span class="text-lg font-mono font-bold">24</span>
          </div>
          <div class="h-px bg-border"></div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-secondary">Points awarded</span>
            <span class="text-lg font-mono font-bold">240</span>
          </div>
          <div class="h-px bg-border"></div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-secondary">Redemptions</span>
            <span class="text-lg font-mono font-bold">3</span>
          </div>
        </div>
      </div>
      <div>
        <p class="text-xs text-gold uppercase tracking-widest font-medium">Insights</p>
        <h2 class="text-3xl font-semibold mt-3">Real-time Dashboard</h2>
        <p class="text-secondary mt-4">Watch your business metrics update live. See check-ins, points, and redemptions as they happen.</p>
        <ul class="mt-6 space-y-3">
          <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success">✓</span> Live visit counter</li>
          <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success">✓</span> 30-day visit chart</li>
          <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success">✓</span> Top customer leaderboard</li>
        </ul>
      </div>
    </div>

    <!-- Campaigns -->
    <div class="grid grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-xs text-gold uppercase tracking-widest font-medium">Engage</p>
        <h2 class="text-3xl font-semibold mt-3">Smart Campaigns</h2>
        <p class="text-secondary mt-4">Run time-limited promotions with point multipliers. Double points weekends, holiday specials, new customer bonuses.</p>
        <ul class="mt-6 space-y-3">
          <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success">✓</span> Customizable multipliers</li>
          <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success">✓</span> Schedule in advance</li>
          <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success">✓</span> Target specific customer segments</li>
        </ul>
      </div>
      <div class="bg-surface border border-border rounded-2xl p-8 h-64 flex items-center justify-center">
        <div class="text-center">
          <span class="px-4 py-2 bg-gold/10 text-gold text-3xl font-mono font-bold rounded-xl">2x</span>
          <p class="text-sm text-secondary mt-4">Weekend Double Points</p>
          <p class="text-xs text-tertiary mt-1">Sat — Sun</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="max-w-6xl mx-auto px-6 py-20">
  <div class="bg-matte rounded-2xl p-12 text-center">
    <h2 class="text-white text-3xl font-semibold">Start building loyalty today</h2>
    <p class="text-white/60 text-lg mt-3">Free plan available. No credit card required.</p>
    <div class="flex items-center justify-center gap-4 mt-6">
      <%= link_to "Get started free", new_registration_path, class: "px-8 py-3 bg-white text-matte text-sm font-medium rounded-xl hover:bg-cream transition-colors" %>
      <%= link_to "See pricing →", pricing_path, class: "text-white/60 text-sm hover:text-white transition-colors" %>
    </div>
  </div>
</section>
