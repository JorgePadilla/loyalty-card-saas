<% content_for(:title, t("pages.pricing.title")) %>

<section class="max-w-6xl mx-auto px-6 pt-24 pb-20">
  <div class="text-center max-w-2xl mx-auto">
    <h1 class="text-4xl font-semibold"><%= t("pages.pricing.heading") %></h1>
    <p class="text-xl text-secondary mt-4"><%= t("pages.pricing.subtitle") %></p>
  </div>

  <div class="grid grid-cols-4 gap-6 mt-16">
    <!-- Free -->
    <div class="bg-surface border border-border rounded-xl p-6">
      <p class="text-sm font-semibold"><%= t("pages.pricing.plans.free.name") %></p>
      <p class="text-4xl font-mono font-bold mt-4">$0<span class="text-sm font-sans font-normal text-secondary"><%= t("pages.pricing.per_month") %></span></p>
      <p class="text-secondary text-sm mt-2"><%= t("pages.pricing.plans.free.tagline") %></p>
      <%= link_to t("pages.pricing.plans.free.cta"), new_registration_path, class: "block w-full mt-6 px-4 py-2.5 border border-border text-sm text-center rounded-xl hover:bg-surface-variant transition-colors" %>
      <ul class="mt-6 space-y-3">
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.free.feature1") %></li>
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.free.feature2") %></li>
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.free.feature3") %></li>
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.free.feature4") %></li>
      </ul>
    </div>

    <!-- Starter -->
    <div class="bg-surface border-2 border-matte rounded-xl p-6 relative">
      <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-0.5 bg-matte text-white text-xs rounded-full"><%= t("pages.pricing.popular_badge") %></span>
      <p class="text-sm font-semibold"><%= t("pages.pricing.plans.starter.name") %></p>
      <p class="text-4xl font-mono font-bold mt-4">$29<span class="text-sm font-sans font-normal text-secondary"><%= t("pages.pricing.per_month") %></span></p>
      <p class="text-secondary text-sm mt-2"><%= t("pages.pricing.plans.starter.tagline") %></p>
      <%= link_to t("pages.pricing.plans.starter.cta"), new_registration_path, class: "block w-full mt-6 px-4 py-2.5 bg-matte text-white text-sm text-center rounded-xl hover:bg-matte-hover transition-colors" %>
      <ul class="mt-6 space-y-3">
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.starter.feature1") %></li>
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.starter.feature2") %></li>
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.starter.feature3") %></li>
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.starter.feature4") %></li>
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.starter.feature5") %></li>
      </ul>
    </div>

    <!-- Pro -->
    <div class="bg-surface border border-border rounded-xl p-6">
      <p class="text-sm font-semibold"><%= t("pages.pricing.plans.pro.name") %></p>
      <p class="text-4xl font-mono font-bold mt-4">$79<span class="text-sm font-sans font-normal text-secondary"><%= t("pages.pricing.per_month") %></span></p>
      <p class="text-secondary text-sm mt-2"><%= t("pages.pricing.plans.pro.tagline") %></p>
      <%= link_to t("pages.pricing.plans.pro.cta"), new_registration_path, class: "block w-full mt-6 px-4 py-2.5 border border-border text-sm text-center rounded-xl hover:bg-surface-variant transition-colors" %>
      <ul class="mt-6 space-y-3">
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.pro.feature1") %></li>
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.pro.feature2") %></li>
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.pro.feature3") %></li>
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.pro.feature4") %></li>
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.pro.feature5") %></li>
      </ul>
    </div>

    <!-- Enterprise -->
    <div class="bg-surface border border-border rounded-xl p-6">
      <p class="text-sm font-semibold"><%= t("pages.pricing.plans.enterprise.name") %></p>
      <p class="text-4xl font-mono font-bold mt-4">$199<span class="text-sm font-sans font-normal text-secondary"><%= t("pages.pricing.per_month") %></span></p>
      <p class="text-secondary text-sm mt-2"><%= t("pages.pricing.plans.enterprise.tagline") %></p>
      <a href="#" class="block w-full mt-6 px-4 py-2.5 border border-border text-sm text-center rounded-xl hover:bg-surface-variant transition-colors"><%= t("pages.pricing.plans.enterprise.cta") %></a>
      <ul class="mt-6 space-y-3">
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.enterprise.feature1") %></li>
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.enterprise.feature2") %></li>
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.enterprise.feature3") %></li>
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.enterprise.feature4") %></li>
        <li class="text-sm text-secondary flex items-center gap-2"><span class="text-success text-xs">✓</span> <%= t("pages.pricing.plans.enterprise.feature5") %></li>
      </ul>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="max-w-3xl mx-auto px-6 py-20">
  <h2 class="text-2xl font-semibold text-center"><%= t("pages.pricing.faq.heading") %></h2>
  <div class="mt-12 space-y-6">
    <% [
      [t("pages.pricing.faq.q1"), t("pages.pricing.faq.a1")],
      [t("pages.pricing.faq.q2"), t("pages.pricing.faq.a2")],
      [t("pages.pricing.faq.q3"), t("pages.pricing.faq.a3")],
      [t("pages.pricing.faq.q4"), t("pages.pricing.faq.a4")]
    ].each do |question, answer| %>
      <div class="border-b border-border pb-6">
        <h3 class="text-sm font-semibold"><%= question %></h3>
        <p class="text-secondary text-sm mt-2"><%= answer %></p>
      </div>
    <% end %>
  </div>
</section>
