<% if pagy && pagy.pages > 1 %>
  <nav class="flex items-center justify-between mt-6 pt-4 border-t border-border">
    <p class="text-secondary text-sm">
      <%= t("pagination.showing", from: pagy.from, to: pagy.to, total: pagy.count) %>
    </p>
    <div class="flex gap-1">
      <% if pagy.previous %>
        <%= link_to t("pagination.previous"), url_for(request.query_parameters.merge(page: pagy.previous)), class: "px-3 py-1.5 text-sm text-secondary hover:text-matte border border-border rounded-lg hover:bg-surface-variant transition-colors" %>
      <% end %>
      <% if pagy.next %>
        <%= link_to t("pagination.next"), url_for(request.query_parameters.merge(page: pagy.next)), class: "px-3 py-1.5 text-sm text-secondary hover:text-matte border border-border rounded-lg hover:bg-surface-variant transition-colors" %>
      <% end %>
    </div>
  </nav>
<% end %>
