<% if recent_visits.any? %>
  <div class="space-y-3">
    <% recent_visits.each do |visit| %>
      <div class="flex items-center justify-between py-2 border-b border-border last:border-0">
        <div>
          <p class="text-matte text-sm font-medium"><%= visit.user.full_name %></p>
          <p class="text-secondary text-xs"><%= visit.service_name %></p>
        </div>
        <div class="text-right">
          <p class="text-matte text-sm font-mono font-medium">+<%= visit.points_earned %> pts</p>
          <p class="text-secondary text-xs"><%= time_ago_in_words(visit.checked_in_at) %> ago</p>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <%= render "shared/empty_state", message: "No visits yet today" %>
<% end %>
