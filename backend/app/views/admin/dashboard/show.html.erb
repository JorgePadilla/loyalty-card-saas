<% content_for(:title, t("admin.dashboard.title")) %>

<%= turbo_stream_from "dashboard_#{current_user.tenant_id}" %>

<div class="mb-6">
  <h1 class="text-2xl font-semibold text-matte"><%= t("admin.dashboard.title") %></h1>
  <p class="text-secondary text-sm mt-1"><%= t("admin.dashboard.subtitle") %></p>
</div>

<!-- Row 1: Stats -->
<div class="grid grid-cols-4 gap-4 mb-4">
  <div id="customers_stat">
    <%= render "shared/stat_card", label: t("admin.dashboard.stats.total_customers"), value: @total_customers %>
  </div>
  <div id="visits_today_stat">
    <%= render "shared/stat_card", label: t("admin.dashboard.stats.visits_today"), value: @visits_today %>
  </div>
  <div id="points_week_stat">
    <%= render "shared/stat_card", label: t("admin.dashboard.stats.points_this_week"), value: number_with_delimiter(@points_this_week) %>
  </div>
  <div id="pending_redemptions_stat">
    <%= render "shared/stat_card", label: t("admin.dashboard.stats.pending_redemptions"), value: @pending_redemptions %>
  </div>
</div>

<!-- Row 2: Chart + Quick Actions -->
<div class="grid grid-cols-4 gap-4 mb-4">
  <div class="col-span-3 bg-surface border border-border rounded-xl p-6">
    <h3 class="text-matte text-sm font-semibold mb-4"><%= t("admin.dashboard.visits_chart_title") %></h3>
    <%= turbo_frame_tag :visits_chart, src: admin_dashboard_chart_path, loading: :lazy do %>
      <div class="h-[200px] flex items-center justify-center">
        <div class="w-6 h-6 border-2 border-border border-t-matte rounded-full animate-spin"></div>
      </div>
    <% end %>
  </div>

  <div class="bg-surface border border-border rounded-xl p-6">
    <h3 class="text-matte text-sm font-semibold mb-4"><%= t("admin.dashboard.quick_actions.title") %></h3>
    <div class="space-y-2">
      <%= link_to t("admin.dashboard.quick_actions.new_reward"), new_admin_reward_path, class: "block w-full px-4 py-2.5 bg-matte text-white text-sm text-center rounded-xl hover:bg-matte-hover transition-colors" %>
      <%= link_to t("admin.dashboard.quick_actions.new_campaign"), new_admin_campaign_path, class: "block w-full px-4 py-2.5 bg-matte text-white text-sm text-center rounded-xl hover:bg-matte-hover transition-colors" %>
      <%= link_to t("admin.dashboard.quick_actions.add_staff"), new_admin_user_path, class: "block w-full px-4 py-2.5 border border-border text-matte text-sm text-center rounded-xl hover:bg-surface-variant transition-colors" %>
    </div>
  </div>
</div>

<!-- Row 3: Recent Activity + Top Customers -->
<div class="grid grid-cols-2 gap-4 mb-4">
  <div class="bg-surface border border-border rounded-xl p-6">
    <h3 class="text-matte text-sm font-semibold mb-4"><%= t("admin.dashboard.recent_activity.title") %></h3>
    <div id="recent_activity">
      <%= render "admin/dashboard/recent_activity", recent_visits: @recent_visits %>
    </div>
  </div>

  <div class="bg-surface border border-border rounded-xl p-6">
    <h3 class="text-matte text-sm font-semibold mb-4"><%= t("admin.dashboard.top_customers.title") %></h3>
    <% if @top_customers.any? %>
      <div class="space-y-3">
        <% @top_customers.each_with_index do |card, i| %>
          <div class="flex items-center gap-3 py-2 border-b border-border last:border-0">
            <span class="text-secondary text-xs font-mono w-4"><%= i + 1 %></span>
            <div class="w-8 h-8 rounded-full bg-surface-variant flex items-center justify-center text-matte text-xs font-semibold">
              <%= card.user.first_name&.first&.upcase %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-matte text-sm font-medium truncate"><%= card.user.full_name %></p>
              <p class="text-secondary text-xs"><%= t("admin.dashboard.top_customers.visits", count: card.visits_count) %></p>
            </div>
            <p class="text-matte text-sm font-mono font-semibold"><%= number_with_delimiter(card.total_points) %> <%= t("admin.common.points_abbr") %></p>
          </div>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state", message: t("admin.dashboard.top_customers.empty") %>
    <% end %>
  </div>
</div>

<!-- Row 4: Active Campaigns + Rewards Overview -->
<div class="grid grid-cols-2 gap-4">
  <div class="bg-surface border border-border rounded-xl p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-matte text-sm font-semibold"><%= t("admin.dashboard.active_campaigns.title") %></h3>
      <%= link_to t("admin.dashboard.active_campaigns.view_all"), admin_campaigns_path, class: "text-secondary text-xs hover:text-matte transition-colors" %>
    </div>
    <% if @active_campaigns.any? %>
      <div class="space-y-3">
        <% @active_campaigns.each do |campaign| %>
          <div class="py-2 border-b border-border last:border-0">
            <div class="flex items-center justify-between">
              <p class="text-matte text-sm font-medium"><%= campaign.name %></p>
              <span class="px-2 py-0.5 bg-gold/10 text-gold text-xs font-mono rounded-full"><%= campaign.multiplier %>x</span>
            </div>
            <p class="text-secondary text-xs mt-1"><%= t("admin.dashboard.active_campaigns.ends", time: time_ago_in_words(campaign.ends_at)) %></p>
          </div>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state", message: t("admin.dashboard.active_campaigns.empty") %>
    <% end %>
  </div>

  <div class="bg-surface border border-border rounded-xl p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-matte text-sm font-semibold"><%= t("admin.dashboard.rewards.title") %></h3>
      <%= link_to t("admin.dashboard.rewards.manage"), admin_rewards_path, class: "text-secondary text-xs hover:text-matte transition-colors" %>
    </div>
    <% if @rewards.any? %>
      <div class="space-y-3">
        <% @rewards.each do |reward| %>
          <div class="flex items-center justify-between py-2 border-b border-border last:border-0">
            <div>
              <p class="text-matte text-sm font-medium"><%= reward.name %></p>
              <p class="text-secondary text-xs"><%= t_enum(:reward, :reward_type, reward.reward_type) %></p>
            </div>
            <span class="text-matte text-sm font-mono font-medium"><%= reward.points_cost %> <%= t("admin.common.points_abbr") %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state", message: t("admin.dashboard.rewards.empty"), action_path: new_admin_reward_path, action_label: t("admin.dashboard.rewards.create_action") %>
    <% end %>
  </div>
</div>
