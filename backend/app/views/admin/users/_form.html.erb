<%= form_with(model: [:admin, user], class: "space-y-6") do |f| %>
  <% if user.errors.any? %>
    <div class="px-4 py-3 bg-danger/10 text-danger text-sm rounded-xl border border-danger/20">
      <ul class="list-disc list-inside">
        <% user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-6">
    <div>
      <%= f.label :first_name, class: "block text-xs text-secondary uppercase tracking-wider font-medium mb-1.5" %>
      <%= f.text_field :first_name, class: "w-full px-4 py-2.5 bg-surface-variant border border-border rounded-xl text-sm text-matte focus:outline-none focus:border-matte transition-colors" %>
    </div>
    <div>
      <%= f.label :last_name, class: "block text-xs text-secondary uppercase tracking-wider font-medium mb-1.5" %>
      <%= f.text_field :last_name, class: "w-full px-4 py-2.5 bg-surface-variant border border-border rounded-xl text-sm text-matte focus:outline-none focus:border-matte transition-colors" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-6">
    <div>
      <%= f.label :email_address, "Email", class: "block text-xs text-secondary uppercase tracking-wider font-medium mb-1.5" %>
      <%= f.email_field :email_address, class: "w-full px-4 py-2.5 bg-surface-variant border border-border rounded-xl text-sm text-matte focus:outline-none focus:border-matte transition-colors" %>
    </div>
    <div>
      <%= f.label :phone, class: "block text-xs text-secondary uppercase tracking-wider font-medium mb-1.5" %>
      <%= f.phone_field :phone, class: "w-full px-4 py-2.5 bg-surface-variant border border-border rounded-xl text-sm text-matte focus:outline-none focus:border-matte transition-colors" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-6">
    <div>
      <%= f.label :role, class: "block text-xs text-secondary uppercase tracking-wider font-medium mb-1.5" %>
      <%= f.select :role, User.roles.keys.map { |r| [r.capitalize, r] }, {}, class: "w-full px-4 py-2.5 bg-surface-variant border border-border rounded-xl text-sm text-matte focus:outline-none focus:border-matte transition-colors" %>
    </div>
    <div>
      <%= f.label :password, user.new_record? ? "Password" : "New Password (leave blank to keep)", class: "block text-xs text-secondary uppercase tracking-wider font-medium mb-1.5" %>
      <%= f.password_field :password, class: "w-full px-4 py-2.5 bg-surface-variant border border-border rounded-xl text-sm text-matte focus:outline-none focus:border-matte transition-colors", required: user.new_record? %>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-4 border-t border-border">
    <%= f.submit class: "px-6 py-2.5 bg-matte text-white text-sm rounded-xl hover:bg-matte-hover transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_users_path, class: "px-6 py-2.5 text-secondary text-sm hover:text-matte transition-colors" %>
  </div>
<% end %>
