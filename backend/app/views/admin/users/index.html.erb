<% content_for(:title, "Users") %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-semibold text-matte">Users</h1>
    <p class="text-secondary text-sm mt-1"><%= @users.count %> total</p>
  </div>
  <%= link_to "Add User", new_admin_user_path, class: "px-4 py-2.5 bg-matte text-white text-sm rounded-xl hover:bg-matte-hover transition-colors" %>
</div>

<!-- Role filter tabs -->
<div class="flex gap-1 mb-6">
  <%= link_to "All", admin_users_path, class: "px-3 py-1.5 text-sm rounded-lg #{@role_filter.blank? ? 'bg-matte text-white' : 'text-secondary hover:text-matte hover:bg-surface-variant'} transition-colors" %>
  <% %w[customer staff manager owner].each do |role| %>
    <%= link_to role.capitalize, admin_users_path(role: role), class: "px-3 py-1.5 text-sm rounded-lg #{@role_filter == role ? 'bg-matte text-white' : 'text-secondary hover:text-matte hover:bg-surface-variant'} transition-colors" %>
  <% end %>
</div>

<div class="bg-surface border border-border rounded-xl overflow-hidden">
  <% if @users.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Name</th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Email</th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Role</th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Points</th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Joined</th>
          <th class="text-right px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr class="border-b border-border last:border-0 hover:bg-surface-variant/50 transition-colors">
            <td class="px-6 py-4">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-surface-variant flex items-center justify-center text-matte text-xs font-semibold">
                  <%= user.first_name&.first&.upcase %>
                </div>
                <%= link_to user.full_name, admin_user_path(user), class: "text-matte text-sm font-medium hover:underline" %>
              </div>
            </td>
            <td class="px-6 py-4 text-secondary text-sm"><%= user.email_address %></td>
            <td class="px-6 py-4">
              <span class="px-2 py-0.5 bg-surface-variant text-matte text-xs rounded-full"><%= user.role.capitalize %></span>
            </td>
            <td class="px-6 py-4 text-matte text-sm font-mono">
              <%= user.loyalty_card&.current_points || "—" %>
            </td>
            <td class="px-6 py-4 text-secondary text-xs"><%= user.created_at.strftime("%b %d, %Y") %></td>
            <td class="px-6 py-4 text-right">
              <%= link_to "Edit", edit_admin_user_path(user), class: "text-secondary text-sm hover:text-matte transition-colors" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <%= render "shared/empty_state", message: "No users found" %>
  <% end %>
</div>
