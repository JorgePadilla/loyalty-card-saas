<% content_for(:title, t("admin.users.index.title")) %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-semibold text-matte"><%= t("admin.users.index.title") %></h1>
    <p class="text-secondary text-sm mt-1"><%= t("admin.users.index.count", count: @users.count) %></p>
  </div>
  <% if policy(User).create? %>
    <%= link_to t("admin.users.index.add_user"), new_admin_user_path, class: "px-4 py-2.5 bg-matte text-white text-sm rounded-xl hover:bg-matte-hover transition-colors" %>
  <% end %>
</div>

<!-- Role filter tabs -->
<div class="flex gap-1 mb-6">
  <%= link_to t("admin.users.index.filter_all"), admin_users_path, class: "px-3 py-1.5 text-sm rounded-lg #{@role_filter.blank? ? 'bg-matte text-white' : 'text-secondary hover:text-matte hover:bg-surface-variant'} transition-colors" %>
  <% %w[customer staff manager owner].each do |role| %>
    <%= link_to t_enum(:user, :role, role), admin_users_path(role: role), class: "px-3 py-1.5 text-sm rounded-lg #{@role_filter == role ? 'bg-matte text-white' : 'text-secondary hover:text-matte hover:bg-surface-variant'} transition-colors" %>
  <% end %>
</div>

<div class="bg-surface border border-border rounded-xl overflow-hidden">
  <% if @users.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.users.index.col_name") %></th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.users.index.col_email") %></th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.users.index.col_role") %></th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.users.index.col_points") %></th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.users.index.col_joined") %></th>
          <th class="text-right px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.users.index.col_actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr class="border-b border-border last:border-0 hover:bg-surface-variant/50 transition-colors">
            <td class="px-6 py-4">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-surface-variant flex items-center justify-center text-matte text-xs font-semibold">
                  <%= user.first_name&.first&.upcase %>
                </div>
                <%= link_to user.full_name, admin_user_path(user), class: "text-matte text-sm font-medium hover:underline" %>
              </div>
            </td>
            <td class="px-6 py-4 text-secondary text-sm"><%= user.email_address %></td>
            <td class="px-6 py-4">
              <span class="px-2 py-0.5 bg-surface-variant text-matte text-xs rounded-full"><%= t_enum(:user, :role, user.role) %></span>
            </td>
            <td class="px-6 py-4 text-matte text-sm font-mono">
              <%= user.loyalty_card&.current_points || t("admin.common.em_dash") %>
            </td>
            <td class="px-6 py-4 text-secondary text-xs"><%= l(user.created_at.to_date, format: :medium) %></td>
            <td class="px-6 py-4 text-right">
              <% if policy(user).update? %>
                <%= link_to t("admin.common.edit"), edit_admin_user_path(user), class: "text-secondary text-sm hover:text-matte transition-colors" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <%= render "shared/empty_state", message: t("admin.users.index.empty") %>
  <% end %>
</div>
