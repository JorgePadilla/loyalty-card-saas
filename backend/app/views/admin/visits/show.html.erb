<% content_for(:title, t("admin.visits.show.title")) %>
<div class="mb-6">
  <h1 class="text-2xl font-semibold text-matte"><%= t("admin.visits.show.title") %></h1>
  <%= link_to t("admin.visits.show.back"), admin_visits_path, class: "text-secondary text-sm hover:text-matte" %>
</div>
<div class="max-w-2xl bg-surface border border-border rounded-xl p-6">
  <dl class="space-y-4">
    <div>
      <dt class="text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.visits.show.customer") %></dt>
      <dd class="text-matte text-sm mt-1"><%= @visit.user.full_name %></dd>
    </div>
    <div>
      <dt class="text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.visits.show.service") %></dt>
      <dd class="text-matte text-sm mt-1"><%= @visit.service_name %></dd>
    </div>
    <div>
      <dt class="text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.visits.show.points_earned") %></dt>
      <dd class="text-matte text-2xl font-mono font-semibold mt-1">+<%= @visit.points_earned %></dd>
    </div>
    <div>
      <dt class="text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.visits.show.staff") %></dt>
      <dd class="text-matte text-sm mt-1"><%= @visit.staff.full_name %></dd>
    </div>
    <div>
      <dt class="text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.visits.show.date") %></dt>
      <dd class="text-matte text-sm mt-1"><%= l(@visit.checked_in_at, format: :long_datetime) %></dd>
    </div>
  </dl>
</div>
