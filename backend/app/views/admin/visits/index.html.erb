<% content_for(:title, t("admin.visits.index.title")) %>

<div class="mb-6">
  <h1 class="text-2xl font-semibold text-matte"><%= t("admin.visits.index.title") %></h1>
  <p class="text-secondary text-sm mt-1"><%= t("admin.visits.index.subtitle") %></p>
</div>

<div class="bg-surface border border-border rounded-xl overflow-hidden">
  <% if @visits.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.visits.index.col_customer") %></th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.visits.index.col_service") %></th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.visits.index.col_staff") %></th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.visits.index.col_points") %></th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.visits.index.col_date") %></th>
        </tr>
      </thead>
      <tbody>
        <% @visits.each do |visit| %>
          <tr class="border-b border-border last:border-0 hover:bg-surface-variant/50 transition-colors">
            <td class="px-6 py-4">
              <%= link_to visit.user.full_name, admin_user_path(visit.user), class: "text-matte text-sm font-medium hover:underline" %>
            </td>
            <td class="px-6 py-4 text-secondary text-sm"><%= visit.service_name %></td>
            <td class="px-6 py-4 text-secondary text-sm"><%= visit.staff.full_name %></td>
            <td class="px-6 py-4 text-matte text-sm font-mono">+<%= visit.points_earned %></td>
            <td class="px-6 py-4 text-secondary text-xs"><%= l(visit.checked_in_at, format: :visit) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <%= render "shared/empty_state", message: t("admin.visits.index.empty") %>
  <% end %>
</div>

<%= render "shared/pagination", pagy: @pagy %>
