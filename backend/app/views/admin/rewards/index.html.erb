<% content_for(:title, "Rewards") %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-semibold text-matte">Rewards</h1>
    <p class="text-secondary text-sm mt-1">Manage rewards your customers can redeem</p>
  </div>
  <%= link_to "New Reward", new_admin_reward_path, class: "px-4 py-2.5 bg-matte text-white text-sm rounded-xl hover:bg-matte-hover transition-colors" %>
</div>

<div class="bg-surface border border-border rounded-xl overflow-hidden">
  <% if @rewards.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Name</th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Type</th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Points</th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Tier</th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Status</th>
          <th class="text-right px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @rewards.each do |reward| %>
          <tr class="border-b border-border last:border-0 hover:bg-surface-variant/50 transition-colors">
            <td class="px-6 py-4">
              <p class="text-matte text-sm font-medium"><%= reward.name %></p>
              <p class="text-secondary text-xs mt-0.5 line-clamp-1"><%= reward.description %></p>
            </td>
            <td class="px-6 py-4 text-secondary text-sm"><%= reward.reward_type.humanize %></td>
            <td class="px-6 py-4 text-matte text-sm font-mono"><%= reward.points_cost %></td>
            <td class="px-6 py-4 text-secondary text-sm"><%= reward.tier_required&.capitalize || "Any" %></td>
            <td class="px-6 py-4">
              <% if reward.active? %>
                <span class="inline-flex px-2 py-0.5 bg-success/10 text-success text-xs rounded-full">Active</span>
              <% else %>
                <span class="inline-flex px-2 py-0.5 bg-secondary/10 text-secondary text-xs rounded-full">Inactive</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-right">
              <%= link_to "Edit", edit_admin_reward_path(reward), class: "text-secondary text-sm hover:text-matte transition-colors" %>
              <%= button_to "Delete", admin_reward_path(reward), method: :delete, class: "text-secondary text-sm hover:text-danger transition-colors ml-3", data: { turbo_confirm: "Are you sure?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <%= render "shared/empty_state", message: "No rewards yet", action_path: new_admin_reward_path, action_label: "Create your first reward" %>
  <% end %>
</div>
