<% content_for(:title, t("admin.rewards.index.title")) %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-semibold text-matte"><%= t("admin.rewards.index.title") %></h1>
    <p class="text-secondary text-sm mt-1"><%= t("admin.rewards.index.subtitle") %></p>
  </div>
  <% if policy(Reward).create? %>
    <%= link_to t("admin.rewards.index.new_reward"), new_admin_reward_path, class: "px-4 py-2.5 bg-matte text-white text-sm rounded-xl hover:bg-matte-hover transition-colors" %>
  <% end %>
</div>

<div class="bg-surface border border-border rounded-xl overflow-hidden">
  <% if @rewards.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.rewards.index.col_name") %></th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.rewards.index.col_type") %></th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.rewards.index.col_points") %></th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.rewards.index.col_tier") %></th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.rewards.index.col_status") %></th>
          <th class="text-right px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.rewards.index.col_actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @rewards.each do |reward| %>
          <tr class="border-b border-border last:border-0 hover:bg-surface-variant/50 transition-colors">
            <td class="px-6 py-4">
              <p class="text-matte text-sm font-medium"><%= reward.name %></p>
              <p class="text-secondary text-xs mt-0.5 line-clamp-1"><%= reward.description %></p>
            </td>
            <td class="px-6 py-4 text-secondary text-sm"><%= t_enum(:reward, :reward_type, reward.reward_type) %></td>
            <td class="px-6 py-4 text-matte text-sm font-mono"><%= reward.points_cost %></td>
            <td class="px-6 py-4 text-secondary text-sm"><%= reward.tier_required.present? ? t_enum(:reward, :tier_required, reward.tier_required) : t("admin.common.any") %></td>
            <td class="px-6 py-4">
              <% if reward.active? %>
                <span class="inline-flex px-2 py-0.5 bg-success/10 text-success text-xs rounded-full"><%= t("admin.common.active") %></span>
              <% else %>
                <span class="inline-flex px-2 py-0.5 bg-secondary/10 text-secondary text-xs rounded-full"><%= t("admin.common.inactive") %></span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-right">
              <% if policy(reward).update? %>
                <%= link_to t("admin.common.edit"), edit_admin_reward_path(reward), class: "text-secondary text-sm hover:text-matte transition-colors" %>
              <% end %>
              <% if policy(reward).destroy? %>
                <%= button_to t("admin.common.delete"), admin_reward_path(reward), method: :delete, class: "text-secondary text-sm hover:text-danger transition-colors ml-3", data: { turbo_confirm: t("admin.common.confirm") } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <%= render "shared/empty_state", message: t("admin.rewards.index.empty"), action_path: (new_admin_reward_path if policy(Reward).create?), action_label: t("admin.rewards.index.create_action") %>
  <% end %>
</div>
