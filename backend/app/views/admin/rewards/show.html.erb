<% content_for(:title, @reward.name) %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-semibold text-matte"><%= @reward.name %></h1>
    <p class="text-secondary text-sm mt-1"><%= @reward.reward_type.humanize %></p>
  </div>
  <div class="flex items-center gap-2">
    <%= link_to "Edit", edit_admin_reward_path(@reward), class: "px-4 py-2 border border-border text-sm text-matte rounded-xl hover:bg-surface-variant transition-colors" %>
    <%= link_to "Back", admin_rewards_path, class: "px-4 py-2 text-secondary text-sm hover:text-matte transition-colors" %>
  </div>
</div>

<div class="max-w-2xl bg-surface border border-border rounded-xl p-6">
  <dl class="space-y-4">
    <div>
      <dt class="text-xs text-secondary uppercase tracking-wider font-medium">Points Cost</dt>
      <dd class="text-matte text-2xl font-mono font-semibold mt-1"><%= @reward.points_cost %></dd>
    </div>
    <div>
      <dt class="text-xs text-secondary uppercase tracking-wider font-medium">Description</dt>
      <dd class="text-matte text-sm mt-1"><%= @reward.description %></dd>
    </div>
    <div>
      <dt class="text-xs text-secondary uppercase tracking-wider font-medium">Tier Required</dt>
      <dd class="text-matte text-sm mt-1"><%= @reward.tier_required&.capitalize || "Any" %></dd>
    </div>
    <div>
      <dt class="text-xs text-secondary uppercase tracking-wider font-medium">Status</dt>
      <dd class="mt-1">
        <% if @reward.active? %>
          <span class="inline-flex px-2 py-0.5 bg-success/10 text-success text-xs rounded-full">Active</span>
        <% else %>
          <span class="inline-flex px-2 py-0.5 bg-secondary/10 text-secondary text-xs rounded-full">Inactive</span>
        <% end %>
      </dd>
    </div>
    <div>
      <dt class="text-xs text-secondary uppercase tracking-wider font-medium">Redemptions</dt>
      <dd class="text-matte text-sm font-mono mt-1"><%= @reward.redemptions.count %></dd>
    </div>
  </dl>
</div>
