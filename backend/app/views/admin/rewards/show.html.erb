<% content_for(:title, @reward.name) %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-semibold text-matte"><%= @reward.name %></h1>
    <p class="text-secondary text-sm mt-1"><%= t_enum(:reward, :reward_type, @reward.reward_type) %></p>
  </div>
  <div class="flex items-center gap-2">
    <%= link_to t("admin.rewards.show.edit"), edit_admin_reward_path(@reward), class: "px-4 py-2 border border-border text-sm text-matte rounded-xl hover:bg-surface-variant transition-colors" %>
    <%= link_to t("admin.rewards.show.back"), admin_rewards_path, class: "px-4 py-2 text-secondary text-sm hover:text-matte transition-colors" %>
  </div>
</div>

<div class="max-w-2xl bg-surface border border-border rounded-xl p-6">
  <dl class="space-y-4">
    <div>
      <dt class="text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.rewards.show.points_cost") %></dt>
      <dd class="text-matte text-2xl font-mono font-semibold mt-1"><%= @reward.points_cost %></dd>
    </div>
    <div>
      <dt class="text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.rewards.show.description") %></dt>
      <dd class="text-matte text-sm mt-1"><%= @reward.description %></dd>
    </div>
    <div>
      <dt class="text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.rewards.show.tier_required") %></dt>
      <dd class="text-matte text-sm mt-1"><%= @reward.tier_required.present? ? t_enum(:reward, :tier_required, @reward.tier_required) : t("admin.common.any") %></dd>
    </div>
    <div>
      <dt class="text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.rewards.show.status") %></dt>
      <dd class="mt-1">
        <% if @reward.active? %>
          <span class="inline-flex px-2 py-0.5 bg-success/10 text-success text-xs rounded-full"><%= t("admin.common.active") %></span>
        <% else %>
          <span class="inline-flex px-2 py-0.5 bg-secondary/10 text-secondary text-xs rounded-full"><%= t("admin.common.inactive") %></span>
        <% end %>
      </dd>
    </div>
    <div>
      <dt class="text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.rewards.show.redemptions") %></dt>
      <dd class="text-matte text-sm font-mono mt-1"><%= @reward.redemptions.count %></dd>
    </div>
  </dl>
</div>
