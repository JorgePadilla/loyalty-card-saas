<% content_for(:title, t("admin.subscriptions.show.title")) %>

<div class="mb-6">
  <h1 class="text-2xl font-semibold text-matte"><%= t("admin.subscriptions.show.title") %></h1>
  <p class="text-secondary text-sm mt-1"><%= t("admin.subscriptions.show.subtitle") %></p>
</div>

<% if params[:checkout] == "success" %>
  <div class="bg-success/10 border border-success/20 rounded-xl p-4 mb-6">
    <p class="text-success text-sm font-medium"><%= t("admin.subscriptions.show.checkout_success") %></p>
  </div>
<% elsif params[:checkout] == "canceled" %>
  <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6">
    <p class="text-amber-700 text-sm font-medium"><%= t("admin.subscriptions.show.checkout_canceled") %></p>
  </div>
<% end %>

<div class="max-w-3xl">
  <!-- Current plan -->
  <div class="bg-surface border border-border rounded-xl p-6 mb-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.subscriptions.show.current_plan") %></p>
        <p class="text-matte text-2xl font-semibold mt-1"><%= t_enum(:tenant, :plan, @tenant.plan) %></p>
      </div>
      <div class="flex items-center gap-3">
        <% if @subscription %>
          <span class="px-3 py-1 <%= @subscription.active? || @subscription.trialing? ? 'bg-success/10 text-success' : 'bg-error/10 text-error' %> text-sm rounded-full"><%= t_enum(:subscription, :status, @subscription.status) %></span>
        <% end %>
        <% if @subscription&.stripe_subscription_id&.start_with?("sub_") %>
          <%= button_to t("admin.subscriptions.show.manage_billing"), billing_portal_admin_subscription_path, method: :post, class: "px-4 py-2 border border-border text-sm rounded-xl hover:bg-surface-variant transition-colors" %>
        <% end %>
      </div>
    </div>
    <% if @subscription&.current_period_end %>
      <p class="text-secondary text-sm mt-3"><%= t("admin.subscriptions.show.next_billing", date: l(@subscription.current_period_end.to_date, format: :long)) %></p>
    <% end %>
    <% if @subscription&.past_due? %>
      <p class="text-error text-sm mt-2"><%= t("admin.subscriptions.show.past_due_warning") %></p>
    <% end %>
  </div>

  <!-- Plan comparison -->
  <h2 class="text-lg font-semibold text-matte mb-4"><%= t("admin.subscriptions.show.available_plans") %></h2>
  <div class="grid grid-cols-4 gap-4">
    <% [
      { key: "free", price: "$0", features: %i[customers staff rewards checkins] },
      { key: "starter", price: "$29", features: %i[customers staff campaigns analytics tiers] },
      { key: "pro", price: "$79", features: %i[customers staff analytics branding support] },
      { key: "enterprise", price: "$199", features: %i[everything staff locations api support] }
    ].each do |plan| %>
      <% is_current = @tenant.plan == plan[:key] %>
      <% plan_name = t("admin.subscriptions.show.plans.#{plan[:key]}.name") %>
      <div class="bg-surface border <%= is_current ? 'border-matte border-2' : 'border-border' %> rounded-xl p-5">
        <p class="text-matte text-sm font-semibold"><%= plan_name %></p>
        <p class="text-matte text-2xl font-mono font-semibold mt-2"><%= plan[:price] %><span class="text-secondary text-xs font-sans"><%= t("admin.subscriptions.show.per_month") %></span></p>
        <ul class="mt-4 space-y-2">
          <% plan[:features].each do |feature| %>
            <li class="text-secondary text-xs flex items-center gap-1.5">
              <span class="text-success">&#10003;</span> <%= t("admin.subscriptions.show.plans.#{plan[:key]}.features.#{feature}") %>
            </li>
          <% end %>
        </ul>
        <% if is_current %>
          <p class="mt-4 text-center text-xs text-secondary font-medium"><%= t("admin.subscriptions.show.current_plan_label") %></p>
        <% elsif plan[:key] == "free" %>
          <p class="mt-4 text-center text-xs text-secondary"><%= t("admin.subscriptions.show.contact_downgrade") %></p>
        <% else %>
          <%= button_to t("admin.subscriptions.show.upgrade_to", plan: plan_name), admin_subscription_path(plan: plan[:key]), class: "mt-4 w-full px-4 py-2 bg-matte text-white text-sm text-center rounded-xl hover:bg-matte-hover transition-colors cursor-pointer" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
