<% content_for(:title, "Campaigns") %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-semibold text-matte">Campaigns</h1>
    <p class="text-secondary text-sm mt-1">Point multiplier promotions</p>
  </div>
  <%= link_to "New Campaign", new_admin_campaign_path, class: "px-4 py-2.5 bg-matte text-white text-sm rounded-xl hover:bg-matte-hover transition-colors" %>
</div>

<div class="bg-surface border border-border rounded-xl overflow-hidden">
  <% if @campaigns.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Name</th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Multiplier</th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Period</th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Status</th>
          <th class="text-right px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @campaigns.each do |campaign| %>
          <tr class="border-b border-border last:border-0 hover:bg-surface-variant/50 transition-colors">
            <td class="px-6 py-4">
              <p class="text-matte text-sm font-medium"><%= campaign.name %></p>
              <p class="text-secondary text-xs mt-0.5 line-clamp-1"><%= campaign.description %></p>
            </td>
            <td class="px-6 py-4">
              <span class="px-2 py-0.5 bg-gold/10 text-gold text-sm font-mono rounded-full"><%= campaign.multiplier %>x</span>
            </td>
            <td class="px-6 py-4 text-secondary text-xs">
              <%= campaign.starts_at.strftime("%b %d") %> — <%= campaign.ends_at.strftime("%b %d, %Y") %>
            </td>
            <td class="px-6 py-4">
              <% if campaign.active_now? %>
                <span class="inline-flex px-2 py-0.5 bg-success/10 text-success text-xs rounded-full">Active Now</span>
              <% elsif campaign.active? %>
                <span class="inline-flex px-2 py-0.5 bg-gold/10 text-gold text-xs rounded-full">Scheduled</span>
              <% else %>
                <span class="inline-flex px-2 py-0.5 bg-secondary/10 text-secondary text-xs rounded-full">Inactive</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-right">
              <%= link_to "Edit", edit_admin_campaign_path(campaign), class: "text-secondary text-sm hover:text-matte transition-colors" %>
              <%= button_to "Delete", admin_campaign_path(campaign), method: :delete, class: "text-secondary text-sm hover:text-danger transition-colors ml-3", data: { turbo_confirm: "Are you sure?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <%= render "shared/empty_state", message: "No campaigns yet", action_path: new_admin_campaign_path, action_label: "Create your first campaign" %>
  <% end %>
</div>
