<% content_for(:title, t("admin.campaigns.index.title")) %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-semibold text-matte"><%= t("admin.campaigns.index.title") %></h1>
    <p class="text-secondary text-sm mt-1"><%= t("admin.campaigns.index.subtitle") %></p>
  </div>
  <%= link_to t("admin.campaigns.index.new_campaign"), new_admin_campaign_path, class: "px-4 py-2.5 bg-matte text-white text-sm rounded-xl hover:bg-matte-hover transition-colors" %>
</div>

<div class="bg-surface border border-border rounded-xl overflow-hidden">
  <% if @campaigns.any? %>
    <table class="w-full">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.campaigns.index.col_name") %></th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.campaigns.index.col_multiplier") %></th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.campaigns.index.col_period") %></th>
          <th class="text-left px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.campaigns.index.col_status") %></th>
          <th class="text-right px-6 py-3 text-xs text-secondary uppercase tracking-wider font-medium"><%= t("admin.campaigns.index.col_actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @campaigns.each do |campaign| %>
          <tr class="border-b border-border last:border-0 hover:bg-surface-variant/50 transition-colors">
            <td class="px-6 py-4">
              <p class="text-matte text-sm font-medium"><%= campaign.name %></p>
              <p class="text-secondary text-xs mt-0.5 line-clamp-1"><%= campaign.description %></p>
            </td>
            <td class="px-6 py-4">
              <span class="px-2 py-0.5 bg-gold/10 text-gold text-sm font-mono rounded-full"><%= campaign.multiplier %>x</span>
            </td>
            <td class="px-6 py-4 text-secondary text-xs">
              <%= campaign.starts_at.strftime("%b %d") %> — <%= campaign.ends_at.strftime("%b %d, %Y") %>
            </td>
            <td class="px-6 py-4">
              <% if campaign.active_now? %>
                <span class="inline-flex px-2 py-0.5 bg-success/10 text-success text-xs rounded-full"><%= t("admin.campaigns.index.active_now") %></span>
              <% elsif campaign.active? %>
                <span class="inline-flex px-2 py-0.5 bg-gold/10 text-gold text-xs rounded-full"><%= t("admin.campaigns.index.scheduled") %></span>
              <% else %>
                <span class="inline-flex px-2 py-0.5 bg-secondary/10 text-secondary text-xs rounded-full"><%= t("admin.campaigns.index.inactive") %></span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-right">
              <%= link_to t("admin.common.edit"), edit_admin_campaign_path(campaign), class: "text-secondary text-sm hover:text-matte transition-colors" %>
              <%= button_to t("admin.common.delete"), admin_campaign_path(campaign), method: :delete, class: "text-secondary text-sm hover:text-danger transition-colors ml-3", data: { turbo_confirm: t("admin.common.confirm") } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <%= render "shared/empty_state", message: t("admin.campaigns.index.empty"), action_path: new_admin_campaign_path, action_label: t("admin.campaigns.index.create_action") %>
  <% end %>
</div>
