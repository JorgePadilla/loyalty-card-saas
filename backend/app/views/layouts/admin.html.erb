<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= content_for?(:title) ? yield(:title) : "Admin" %> — Loyalty Card</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= action_cable_meta_tag %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="h-full bg-cream font-sans">
  <div class="flex h-full">
    <!-- Sidebar -->
    <aside class="fixed inset-y-0 left-0 w-60 bg-matte flex flex-col z-30" data-controller="sidebar">
      <!-- Logo -->
      <div class="px-6 py-5 border-b border-white/10">
        <h1 class="text-white text-lg font-semibold tracking-tight">Loyalty Card</h1>
        <p class="text-white/50 text-xs mt-0.5"><%= current_user&.tenant&.name %></p>
      </div>

      <!-- Nav -->
      <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
        <%= admin_nav_link "Dashboard", admin_root_path, icon: "grid" %>
        <%= admin_nav_link "Customers", admin_users_path(role: :customer), icon: "users" %>
        <%= admin_nav_link "Rewards", admin_rewards_path, icon: "gift" %>
        <%= admin_nav_link "Campaigns", admin_campaigns_path, icon: "zap" %>
        <%= admin_nav_link "Visits", admin_visits_path, icon: "calendar" %>
        <%= admin_nav_link "Subscription", admin_subscription_path, icon: "credit-card" %>
      </nav>

      <!-- User -->
      <div class="px-4 py-4 border-t border-white/10">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-gold flex items-center justify-center text-matte text-sm font-semibold">
            <%= current_user&.first_name&.first&.upcase %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-white text-sm font-medium truncate"><%= current_user&.full_name %></p>
            <p class="text-white/50 text-xs truncate"><%= current_user&.role&.capitalize %></p>
          </div>
        </div>
        <div class="mt-3">
          <%= button_to "Sign out", session_path, method: :delete, class: "text-white/50 text-xs hover:text-white transition-colors" %>
        </div>
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 ml-60 overflow-y-auto">
      <% if flash[:notice] %>
        <div class="mx-8 mt-6 px-4 py-3 bg-success/10 text-success text-sm rounded-xl border border-success/20" data-controller="flash">
          <%= flash[:notice] %>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="mx-8 mt-6 px-4 py-3 bg-error/10 text-error text-sm rounded-xl border border-error/20" data-controller="flash">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <div class="px-8 py-6">
        <%= yield %>
      </div>
    </main>
  </div>
</body>
</html>
