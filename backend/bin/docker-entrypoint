#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# If running the rails server then create or migrate existing database
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare

  # Ensure Solid Trifecta schemas are loaded (cache, queue, cable).
  # With a shared DATABASE_URL, db:prepare may skip schema:load for secondary DBs.
  ./bin/rails db:schema:load:cache db:schema:load:queue db:schema:load:cable 2>/dev/null || true
fi

exec "${@}"
